# 数据库配置
MYSQL_HOST=your_mysql_host
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_PORT=3306
MYSQL_DATABASE=it_asset_management

# Flask 密钥（请生成一个随机的 SECRET_KEY）
SECRET_KEY=your_secret_key_here

# SSL/TLS配置
# 生产环境必须启用 HTTPS
SSL_ENABLED=false
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# SSH配置
SSH_HOST=your_ssh_host
SSH_PORT=22
SSH_USERNAME=your_ssh_username
SSH_PASSWORD=your_ssh_password

# SMTP邮件配置
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=noreply@example.com
FROM_NAME=IT运维管理平台

# JumpServer API配置
JUMPSERVER_ACCESS_KEY_ID=your_access_key_id
JUMPSERVER_ACCESS_KEY_SECRET=your_access_key_secret

# K8S数据库配置
K8S_MYSQL_HOST=your_k8s_mysql_host
K8S_MYSQL_USER=your_k8s_mysql_user
K8S_MYSQL_PASSWORD=your_k8s_mysql_password
K8S_MYSQL_PORT=3306
K8S_MYSQL_DATABASE=it_asset_management

# 邮件测试模式配置
EMAIL_TEST_MODE=False
TEST_EMAIL=test@example.com
