                                </div>
                                
                                <div class="col-lg-4 col-md-6">
                                    <div class="permission-category">
                                        <h6 class="text-info mb-3">
                                            <i class="fas fa-shield-alt me-1"></i>BSECP
                                        </h6>
                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permAuthQuery" value="auth_query">
                                                <label class="form-check-label" for="permAuthQuery">
                                                    <i class="fas fa-search me-1"></i>授权查询
                                                </label>
                                            </div>
