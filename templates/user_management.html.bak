                                <div class="col-lg-4 col-md-6">
                                    <div class="permission-category">
                                        <h6 class="text-success mb-3">
                                            <i class="fas fa-cogs me-1"></i>资产管理
                                        </h6>
                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permPhysicalMachines" value="physical_machines">
                                                <label class="form-check-label" for="permPhysicalMachines">
                                                    <i class="fas fa-server me-1"></i>物理机管理
                                                </label>
                                            </div>
                                        </div>
                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permVirtualMachines" value="virtual_machines">
                                                <label class="form-check-label" for="permVirtualMachines">
                                                    <i class="fas fa-cloud me-1"></i>虚拟机管理
                                                </label>
                                            </div>
                                        </div>
                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permNamespaces" value="namespaces">
                                                <label class="form-check-label" for="permNamespaces">
                                                    <i class="fas fa-layer-group me-1"></i>NameSpace管理
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-lg-4 col-md-6">
                                    <div class="permission-category">
                                        <h6 class="text-warning mb-3">
                                            <i class="fas fa-network-wired me-1"></i>映射管理
                                        </h6>
                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permDomainMapping" value="domain_mapping">
                                                <label class="form-check-label" for="permDomainMapping">
                                                    <i class="fas fa-globe me-1"></i>域名映射
                                                </label>
                                            </div>
                                        </div>
                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permPortMapping" value="port_mapping">
                                                <label class="form-check-label" for="permPortMapping">
                                                    <i class="fas fa-exchange-alt me-1"></i>端口映射
                                                </label>
                                            </div>
                                        </div>
