                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permAuthDetail" value="auth_detail">
                                                <label class="form-check-label" for="permAuthDetail">
                                                    <i class="fas fa-file-alt me-1"></i>授权详情
                                                </label>
                                            </div>
                                        </div>
                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permBsecpModules" value="bsecp_modules">
                                                <label class="form-check-label" for="permBsecpModules">
                                                    <i class="fas fa-puzzle-piece me-1"></i>Module管理
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-lg-4 col-md-6">
                                    <div class="permission-category">
                                        <h6 class="text-danger mb-3">
                                            <i class="fas fa-cube me-1"></i>行云管家
                                        </h6>
                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permBastionManagement" value="bastion_management">
                                                <label class="form-check-label" for="permBastionManagement">
                                                    <i class="fas fa-lock me-1"></i>堡垒机管理
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-lg-4 col-md-6">
                                    <div class="permission-category">
                                        <h6 class="text-purple mb-3">
                                            <i class="fas fa-chart-line me-1"></i>运维监控
                                        </h6>
                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permHostMonitoring" value="host_monitoring">
                                                <label class="form-check-label" for="permHostMonitoring">
                                                    <i class="fas fa-cpu me-1"></i>主机资源监控
                                                </label>
                                            </div>
                                        </div>
                                        <div class="permission-item">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="permK8sMonitoring" value="k8s_monitoring">
                                                <label class="form-check-label" for="permK8sMonitoring">
                                                    <i class="fas fa-microchip me-1"></i>K8S资源监控
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>取消
                    </button>
                    <button type="button" class="btn btn-primary" id="savePermissionBtn">
